# FortiGate / FortiAnalyzer MCP Server Configuration
# Copy this to .env and fill in your values
#
# Three modes supported:
#   1. FortiGate only      — set FORTIGATE_HOST + FORTIGATE_API_KEY
#   2. FortiAnalyzer only  — set FAZ_HOST + FAZ_API_TOKEN (or FAZ_USER/FAZ_PASSWORD)
#   3. Both (hybrid)       — set all of the above
#
# At least one of FortiGate or FortiAnalyzer must be configured.

# ============================================================================
# FortiGate Configuration (optional if using FortiAnalyzer only)
# ============================================================================

# FortiGate IP or hostname
FORTIGATE_HOST=192.168.1.1

# HTTPS port (default 443)
FORTIGATE_PORT=443

# API token — generate in FortiGate GUI:
#   System > Admin Profiles > create a read-only profile
#   System > Administrators > create REST API admin with that profile
#   Copy the generated API token
FORTIGATE_API_KEY=your-api-token-here

# Set to "true" if using a valid TLS certificate (default: false for self-signed)
FORTIGATE_VERIFY_SSL=false

# VDOM (Virtual Domain) — default "root"
# Safe on non-VDOM firewalls: FortiOS silently ignores the parameter.
# For multi-VDOM firewalls, set this to target a specific VDOM by default.
# Each tool also accepts a per-call vdom override.
# FORTIGATE_VDOM=root

# ============================================================================
# SSH Configuration (optional — enables execute_cli_ssh tool)
# ============================================================================

# SSH into FortiGate for diagnose commands and debug output
FORTIGATE_SSH_USER=admin
FORTIGATE_SSH_PASSWORD=your-password-here
FORTIGATE_SSH_PORT=22

# Or use key-based auth instead of password:
# FORTIGATE_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

# ============================================================================
# FortiAnalyzer Configuration (optional — enables centralized log search)
# ============================================================================

# FortiAnalyzer IP or hostname
# FAZ_HOST=10.0.0.50

# HTTPS port (default 443)
# FAZ_PORT=443

# Authentication — use API token (recommended) OR username/password
# API token: create in System Settings > Admin > Administrators (REST API Admin type)
# FAZ_API_TOKEN=your-faz-api-token

# Or use session-based auth:
# FAZ_USER=admin
# FAZ_PASSWORD=your-faz-password

# ADOM (Administrative Domain) — default "root"
# FAZ_ADOM=root

# Set to "true" if using a valid TLS certificate (default: false for self-signed)
# FAZ_VERIFY_SSL=false
